.rangeSlider {
  position: relative;
}

.rangeSlider [type="range"] {
  width: 100%;
  -webkit-appearance: none;
  height: 8px;
  border-radius: 6px;
  background: #f1f1f1;
  outline: none;
  padding: 0;
  margin: 0;
  transform: rotateZ(270deg);
  width: 258px;
  position: absolute;
  right: 30%;
  bottom: 150px;
}

/* custom thumb */
.rangeSlider [type="range"]::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 25px;
  height: 25px;
  border-radius: 50%;
  background: #7a00ff;
  border: #f9ca24 5px solid;
  cursor: pointer;
  -webkit-transition: background .15s ease-in-out;
  transition: background .15s ease-in-out;
}

.rangeSlider [type="range"]::-webkit-slider-thumb:hover {
  background: #7a00ff;
}

.rangeSlider [type="range"]::-moz-range-thumb {
  width: 20px;
  height: 20px;
  border: 0;
  border-radius: 50%;
  background: #7a00ff;
  border: #f9ca24 5px solid; cursor: pointer;
  -webkit-transition: background .15s ease-in-out;
  transition: background .15s ease-in-out;
}

.rangeSlider [type="range"]::-moz-range-thumb:hover {
  background: #7a00ff;
}

/* remove border */
input::-moz-focus-inner, input::-moz-focus-outer {
  border: 0;
}

.laserController {
    display: grid;
    align-items: center;
    width: 44px;
    border-radius: 8px;
    border: 0.5px solid #99A5FF;
    background: linear-gradient(270deg, rgba(255, 255, 255, 0.20) 0%, rgba(255, 255, 255, 0.00) 36.46%, rgba(255, 255, 255, 0.00) 67.19%, rgba(255, 255, 255, 0.20) 100%);
    backdrop-filter: blur(15px);
    position: absolute;
    right: 30%;
    height: 230px;
    top: 20px;
}
  
.laserControllerButton {
    background-color: transparent;
    border: none;
    font-size: 1rem;
    cursor: pointer;
    font-size: 30px;
    color: #fff;
}
  
.laserValue {
    border: none;
    text-align: center;
    font-size: 1rem;
    margin: 0 10px;
    background-color: transparent;
    color: #fff;
    font-family: PT Mono;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 0.96px;
}