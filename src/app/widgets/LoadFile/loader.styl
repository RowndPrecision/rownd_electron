.loader {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(0, 0, 0, 0.6);

    .loaderIcon {
        color: #9747FF;
        position: absolute;
        top: 50%;
        left: 50%;
        > * {
            font-size: 48px;
        }
    }

    .loaderText {
        margin: 15px 0 10px 0;
        color: #9747FF;
        position: absolute;
        top: 54%;
        left: 50%;
    }
}
