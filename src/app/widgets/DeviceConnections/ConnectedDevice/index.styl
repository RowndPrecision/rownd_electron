.connectedDevice {
    flex-shrink: 0;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    align-items: start;
    padding: 10px;
    width: 100%;
    gap: 10px;
    min-height: 160px;
}

.connected {
    border: 0.2px solid #36A900;
    background: rgba(54, 169, 0, 0.20);
}

.disconnected {
    border: 0.2px solid #DE0050;
    background: rgba(222, 0, 80, 0.30);
}

.deviceNameTitle {
    color: var(--linear-gra, #FFF);
    font-family: Poppins;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    text-transform: capitalize;
}

.connectionStatus {
    display: flex;
}

.connectionStatusTitle {
    color: var(--linear-gra, #FFF);
    font-family: Poppins;
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 12px; /* 100% */
    text-transform: capitalize;
    display: flex;
    align-items: center;
}

.connectionStatusIcon {
    width: 24px;
    height: 24px;
    margin-right: 4px;
}

.infoText {
    color: var(--linear-gra, #FFF);
    font-family: "PT Sans";
    font-size: 12px;
    font-style: normal;
    font-weight: 400;
    line-height: 12px; /* 100% */
}

.action {
    margin: auto;
}

