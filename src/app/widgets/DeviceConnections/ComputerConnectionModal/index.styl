.computerConnectedModal {
    padding: 0 20px 20px 20px;
    border: 0.5px solid #36A900;
    background: #111219;
    border-radius: 8px;
    margin: -4px;

    &Header {
        background: rgba(54, 169, 0, 0.2);
        display: flex;
        align-items: center;
        margin: 0 -20px;
        height: 60px;
        justify-content: center;

      &Icon {
        width: 28px;
        height: 28px;
    }
  
        &Text {
            margin-left: 8px;
            color: #36A900;
            font-family: "PT Sans";
            font-size: 20px;
            font-style: normal;
            font-weight: 400;
            line-height: 14px;
            letter-spacing: 0.7px;
            text-transform: capitalize;
        }
    }  
     &Content {
        display: grid;
        grid-template-columns: auto auto;
        gap: 20px;

        &AxePositions {
            padding: 40px;
            display: grid;
            gap: 10px;
        }

        &Speedometer {
            width: 320px;
            padding: 40px;
            height: 0
        }
    } 

    &Footer {
        display: flex;
        justify-content: center;
        position: relative;
        z-index: 999
    }
}